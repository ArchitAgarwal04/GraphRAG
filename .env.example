# ============================================================
#  8_GraphRAG_KG_Agent — Environment Variables
#  Copy this to .env and fill in your values.
# ============================================================

# Groq API (LLM for relationship extraction)
# Get free key at: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# LLM model
GROQ_MODEL=llama-3.1-8b-instant

# ── Neo4j (Option A — AuraDB Cloud, recommended) ──────────
# Sign up free at: https://neo4j.com/cloud/aura
# NEO4J_URI=neo4j+s://xxxxxxxx.databases.neo4j.io
# NEO4J_USERNAME=neo4j
# NEO4J_PASSWORD=your_aura_password_here

# ── Neo4j (Option B — Local Desktop) ──────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_local_password_here
